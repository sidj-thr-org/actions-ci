{
  "name": "@sidj-thr/actions-ci",
  "version": "0.3.0",
  "description": "CI utilities — a modular, extensible CLI for GitHub automation",
  "author": "sidj-thr",
  "license": "Apache-2.0",
  "main": "./main.js",
  "bin": {
    "actions-ci": "main.js"
  },
  "keywords": [
    "ci",
    "github-actions",
    "cli"
  ],
  "files": [
    "main.js",
    "lib/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test:unit": "brittle-node test/unit/*.test.js test/unit/**/*.test.js",
    "test": "npm run test:unit",
    "audit": "npm audit --audit-level=high"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": "https://github.com/sidj-thr/actions-ci/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidj-thr/actions-ci.git"
  },
  "homepage": "https://github.com/sidj-thr/actions-ci#readme",
  "dependencies": {
    "@actions/github": "^9.0.0",
    "@octokit/auth-app": "^8.2.0",
    "paparam": "^1.10.1"
  },
  "devDependencies": {
    "brittle": "^3.10.1",
    "standard": "^17.1.2"
  }
}
